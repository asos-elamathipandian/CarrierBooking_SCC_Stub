# Normalise all text files to LF in the repo; Git converts to CRLF on Windows checkout.
* text=auto eol=lf

# Force these specific types to always use LF
*.js    text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.xml   text eol=lf
*.env   text eol=lf
*.ppk   binary
*.xlsx  binary
*.pptx  binary
*.png   binary
*.jpg   binary
