# ──────────────────────────────────────────────
# CarrierBookingStub — Environment Variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real secrets.
# ──────────────────────────────────────────────

# ── SFTP (E2open) ──────────────────────────────
# Required: host and username must be set to enable SFTP uploads.
# If unset, the app falls back to saving XMLs locally in output/.
SFTP_HOST=sftp.e2open.com
SFTP_PORT=22
SFTP_USERNAME=your-username

# Auth: provide EITHER a password OR a path to a PEM/PPK private key (not both).
SFTP_PASSWORD=
SFTP_PRIVATE_KEY_PATH=./config/your-key.ppk
# If the private key is passphrase-protected, set the passphrase here.
SFTP_PRIVATE_KEY_PASSPHRASE=

# Remote directory where VBKREQ XML files are deposited.
SFTP_UPLOAD_PATH=/e2open/b2b/scpusers2/e2net/E2NETSTG/e2c0000e9a-3358ade21b-0/in

# ── Azure Blob Storage (Bible / Supplier data) ─
# Legacy blob store for bible/supplier Excel files.
# Leave blank to disable Azure Blob and use local files instead.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=

# PO feed blob store (ASN / PO XML feeds).
# Leave blank to use local sample files in samples/feeds/.
AZURE_PO_FEED_CONNECTION_STRING=

# ── SharePoint (Supplier Template Sync) ───────────────────────────────────────
# App Registration in Azure AD with Sites.ReadWrite.All application permission.
SP_TENANT_ID=REPLACE-WITH-TENANT-ID
SP_CLIENT_ID=REPLACE-WITH-CLIENT-ID
SP_CLIENT_SECRET=REPLACE-WITH-CLIENT-SECRET

# Full URL of the SharePoint site.
SP_SITE_URL=https://asos.sharepoint.com/sites/YourSite

# Folder path inside the default document library where supplier subfolders live.
# Each subfolder = one supplier (e.g. /Carrier Booking/Templates/SUPPLIER_A).
SP_FOLDER_PATH=/Carrier Booking/Templates

# Scheduler: comma-separated HH:MM times to run the sync each day.
SP_SCHEDULE=09:00,13:00

# ── Email Ingestor (Supplier Templates via Email) ─────────────────────────────
# When set, the scheduler reads this mailbox BEFORE each SP sync and uploads
# any Excel attachments directly into the correct SharePoint supplier folder.
#
# Azure AD setup (one-off):
#   - Same App Registration as SharePoint (SP_CLIENT_ID / SP_CLIENT_SECRET)
#   - Add application permission: Mail.ReadWrite
#   - Grant admin consent
#   - Optionally scope the permission to the mailbox only via Exchange access policies
#
# The dedicated ASOS mailbox that suppliers send their templates to.
EMAIL_INGEST_MAILBOX=carrier-templates@asos.com

# JSON map of sender email address (or domain) → SharePoint supplier folder name.
# Exact email address is checked first, then domain. Unrecognised senders get a
# folder derived from their display name.
# Example: {"supplier-a.com":"SUPPLIER_A","buyer@vendorb.com":"VENDOR_B"}
EMAIL_SUPPLIER_MAP={}

# Optional: name of a mailbox subfolder to move processed emails into after upload.
# If not set, processed emails are only marked as read.
EMAIL_PROCESSED_FOLDER=Processed
