# ──────────────────────────────────────────────
# CarrierBookingStub — Environment Variables
# Copy this file to .env and fill in the values.
# .env is git-ignored; never commit real secrets.
# ──────────────────────────────────────────────

# ── SFTP (E2open) ──────────────────────────────
# Required: host and username must be set to enable SFTP uploads.
# If unset, the app falls back to saving XMLs locally in output/.
SFTP_HOST=bastion3.e2open.net
SFTP_PORT=22
SFTP_USERNAME=e2c0000e9a-3358ade21b-0

# Auth: provide EITHER a password OR a path to a PEM private key (not both).
SFTP_PASSWORD=fishfinger
SFTP_PRIVATE_KEY_PATH=C:\Users\elamathi.pandian\CarrierBookingStub\config\asos-david-ayres.ppk

# Remote directory where VBKREQ XML files are deposited.
SFTP_UPLOAD_PATH=/e2open/b2b/scpusers2/e2net/E2NETSTG/e2c0000e9a-3358ade21b-0/in

# ── Azure Blob Storage (Bible / Supplier data) ─
# Legacy blob store for bible/supplier Excel files.
# Leave blank to disable Azure Blob and use local files instead.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=

# PO feed blob store (ASN / PO XML feeds).
# Leave blank to use local sample files in samples/feeds/.
AZURE_PO_FEED_CONNECTION_STRING=
